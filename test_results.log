ent(135deg, #fdf2f8, #fce7f3);\n        background-size: cover;\n        background-position: center;\n        position: relative;\n        padding: 48px 16px;\n        text-align: center;\n    }\n    .hero-section::before {\n        content: "";\n        position: absolute;\n        inset: 0;\n        background: rgba(255, 241, 242, 0.82);\n        z-index: 0;\n    }\n    .hero-content {\n        position: relative;\n        z-index: 1;\n    }\n\n    /* ── Product grid ── */\n    .retail-grid {\n        display: grid;\n        grid-template-columns: repeat(2, 1fr);\n        gap: 10px;\n        padding: 0 8px;\n        box-sizing: border-box;\n        width: 100%;\n    }\n    @media (min-width: 640px) {\n        .retail-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }\n    }\n    @media (min-width: 1024px) {\n        .retail-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }\n    }\n\n    /* ── Product card ── */\n    .product-card {\n        background: white;\n        border-radius: 16px;\n        padding: 8px;\n        box-shadow: 0 1px 6px rgba(0,0,0,0.07);\n        border: 1px solid #fff1f2;\n        display: flex;\n        flex-direction: column;\n        position: relative;\n        overflow: hidden;\n        min-width: 0;\n        box-sizing: border-box;\n    }\n    .product-card img.prod-img {\n        width: 100%;\n        height: 140px;\n        object-fit: contain;\n        border-radius: 14px;\n    }\n    @media (min-width: 768px) {\n        .product-card img.prod-img { height: 200px; }\n    }\n\n    /* ── Product name ── */\n    .prod-name {\n        font-weight: bold;\n        font-size: 0.88rem;\n        margin-top: 8px;\n        margin-bottom: 4px;\n        white-space: nowrap;\n        overflow: hidden;\n        text-overflow: ellipsis;\n        color: #1e293b;\n    }\n    @media (min-width: 768px) {\n        .prod-name { font-size: 1rem; }\n    }\n\n    /* ── Price ── */\n    .prod-price {\n        font-size: 1rem;\n        font-weight: 900;\n        color: #9f1239;\n        margin-bottom: 10px;\n    }\n\n    /* ── Share button ── */\n    .share-btn {\n        position: absolute;\n        top: 8px;\n        right: 8px;\n        background: #ffe4e6;\n        border: none;\n        border-radius: 50%;\n        padding: 6px;\n        cursor: pointer;\n        z-index: 2;\n    }\n\n    /* ── Size select ── */\n    .input-field {\n        width: 100%;\n        border: 1px solid #e2e8f0;\n        border-radius: 8px;\n        padding: 5px 8px;\n        font-size: 0.82rem;\n        margin-bottom: 6px;\n    }\n\n    /* ── Cart buttons ── */\n    .btn-add-cart {\n        width: 100%; padding: 10px 0; border-radius: 30px;\n        font-weight: 700; font-size: 0.82rem;\n        border: 2px solid #be185d; background: white; color: #be185d;\n        cursor: pointer; letter-spacing: 0.03em; transition: background 0.15s;\n    }\n    .btn-add-cart:hover { background: #fff1f2; }\n    @media (min-width: 768px) { .btn-add-cart { font-size: 0.92rem; } }\n    .btn-buy-now {\n        width: 100%; padding: 10px 0; border-radius: 30px;\n        font-weight: 700; font-size: 0.82rem; border: none;\n        background: linear-gradient(135deg, #be185d 0%, #f472b6 100%);\n        color: white; cursor: pointer; letter-spacing: 0.03em;\n        box-shadow: 0 3px 10px rgba(190,24,93,0.25);\n        margin-top: 8px; transition: opacity 0.15s;\n    }\n    .btn-buy-now:hover { opacity: 0.9; }\n    @media (min-width: 768px) { .btn-buy-now { font-size: 0.92rem; } }\n    .unit-counter {\n        border: 2px solid #fda4af; background: #fff1f2; border-radius: 30px;\n        display: flex; align-items: center; justify-content: space-between;\n        padding: 3px 8px; margin-bottom: 8px;\n    }\n    .unit-counter button {\n        width: 28px; height: 28px; border-radius: 50%;\n        background: #ffe4e6; border: none; font-size: 1rem;\n        font-weight: bold; color: #be185d; cursor: pointer;\n        display: flex; align-items