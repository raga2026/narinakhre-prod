ct/public/products/102024BRHR009_1.webp&#34;)">\n                    <img src="/static/assets/share.svg"\n                         alt="Share" style="width:16px;height:16px;" />\n                </button>\n\n                <!-- Image carousel -->\n                <a href="/retail/product/53">\n                    \n                    <img id="carousel-img-53"\n                         class="prod-img carousel-img"\n                         src="https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_1.webp"\n                         alt="Nari Nakhre Multicolor Stone &amp; Bead Saree Pin (Pack of 6)"\n                         data-images=\'["https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_1.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_2.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_3.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_4.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_5.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_6.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_7.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_8.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/102024BRHR009_9.webp"]\'\n                         data-index="0"\n                         onerror="this.onerror=null;this.src=\'/static/assets/products/default.jpg\';" />\n                </a>\n\n                <!-- Name -->\n                <div class="prod-name">Nari Nakhre Multicolor Stone &amp; Bead Saree Pin (Pack of 6)</div>\n\n                <!-- Price -->\n                <div class="prod-price">₹200</div>\n\n                <!-- Size select for bangles -->\n                \n                \n                <select class="input-field size-select" id="size-102024BRHR009">\n                    \n                    <option value="Free Size">Free Size</option>\n                    \n                </select>\n                \n\n                <!-- Cart actions -->\n                <div class="cart-container mt-auto" id="cart-action-102024BRHR009">\n                    <!-- Qty select -->\n                    <select class="input-field qty-select" id="qty-102024BRHR009">\n                        <option value="1" selected>1</option>\n                        <option value="2">2</option>\n                        <option value="3">3</option>\n                        <option value="4">4</option>\n                        <option value="5">5</option>\n                    </select>\n                    <!-- Add to Cart -->\n                    <button class="btn-add-cart add-to-cart-btn"\n                            data-sku="102024BRHR009"\n                            data-price="200"\n                            data-name="Nari Nakhre Multicolor Stone &amp; Bead Saree Pin (Pack of 6)">\n                        🛒 Add to Cart\n                    </button>\n                    <!-- Unit counter (hidden by default) -->\n                    <div class="unit-counter hidden">\n                        <button class="decrement-btn">-</button>\n                        <span class="qty-display">1</span>\n                        <button class="increment-btn">+</button>\n                    </div>\n                    <!-- Buy Now -->\n                    <button class="btn-buy-now buy-now-btn"\n                            data-sku="102024BRHR009"\n                            data-price="200"\n                            data-name="Nari Nakhre Multicolor Stone &amp; Bead Saree Pin (Pack of 6)">\n                        ⚡ Buy Now\n                    </button>\n                </div>\n            </div>\n            \n        </div>\n\n        \n    </div>\n    \n</div>\n\n<script>\n/* ── Share ── */\nasync function shareProduct(name, url, imageUrl) {\n    const shareData = { title: name, text: \'Check out \' + name + \' on Nari Nakhre\', url: url };\n    if (imageUrl && navigator.canShare && window.File) {\n        try {\n            const r = await fetch(imageUrl, { mode: \'cors\' });\n            if (r.ok) {\n                const blob = await r.blob();\n                const file = new File([blob], name.replace(/\\W+/g,\'-\').toLowerCase()+\'.jpg\', { type: blob.type });\n                const sd = { ...shareData, files: [file] };\n                if (navigator.canShare(sd)) { await navigator.share(sd); return; }\n            }\n        } catch(e) {}\n    }\n    if (navigator.share) { navigator.share(shareData).catch(()=>{}); }\n    else {\n        const msg = encodeURIComponent(shareData.text + \' \' + shareData.url);\n        window.open(\'https://wa.me/?text=\' + msg, \'_blank\');\n    }\n}\n\ndocument.addEventListener(\'DOMContentLoaded\', function () {\n\n    /* ── Hero background from Supabase ── */\n    var heroSec = document.getElementById(\'hero-section\');\n    var heroImages = ["https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/062025VSB032_1.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/012025BNGRE014_1.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/052025KAD021_1.webp", "https://eopqwvssznmxfxrfzqbx.supabase.co/storage/v1/object/public/products/012025HCF012_1.webp"];\n    if (heroImages.length > 0) {\n        var heroIdx = 0;\n        function setHero() {\n            heroSec.style.backgroundImage = "url(\'" + heroImages[heroIdx] + "\')";\n            heroIdx = (heroIdx + 1) % heroImages.length;\n        }\n        setHero();\n        setInterval(setHero, 5000);\n    }\n\n    /* ── Product image carousel ── */\n    document.querySelectorAll(\'.carousel-img[data-images]\').forEach(function (img) {\n        var imgs = [];\n        try { imgs = JSON.parse(img.getAttribute(\'data-images\') || \'[]\'); } catch(e) {}\n        if (imgs.length > 1) {\n            var idx = 0;\n            setInterval(function () {\n                idx = (idx + 1) % imgs.length;\n                img.src = imgs[idx];\n            }, 3000);\n        }\n    });\n\n    /* ── Cart logic ── */\n    function getSize(container) {\n        const s = container.querySelector(\'.size-select\');\n        return s ? s.value : \'Standard\';\n    }\n    function updateCartCount(data) {\n        const el = document.getElementById(\'cart-count\');\n        if (el && data && typeof data.cart_count !== \'undefined\') el.textContent = data.cart_count;\n    }\n\n    document.querySelectorAll(\'.cart-container\').forEach(function (container) {\n        const addBtn = container.querySelector(\'.add-to-cart-btn\');\n        const buyBtn = container.querySelector(\'.buy-now-btn\');\n        const counter = container.querySelector(\'.unit-counter\');\n        const qtySel = container.querySelector(\'.qty-select\');\n        const minusBtn = container.querySelector(\'.decrement-btn\');\n        const plusBtn = container.querySelector(\'.increment-btn\');\n        const qtyDisplay = container.querySelector(\'.qty-display\');\n\n        function getQty() { return parseInt(qtySel ? qtySel.value : 1); }\n        function postCart(sku, qty, price, size) {\n            return fetch(\'/update-cart\', {\n                method: \'POST\',\n                headers: { \'Content-Type\': \'application/json\' },\n                body: JSON.stringify({ product_id: sku, qty: qty, price: price, size: size })\n            }).then(r => r.json());\n        }\n\n        if (addBtn) {\n            addBtn.addEventListener(\'click\', function (e) {\n                e.preventDefault();\n                const sku = addBtn.dataset.sku, price = addBtn.dataset.price;\n                postCart(sku, getQty(), price, getSize(container)).then(data => {\n                    addBtn.style.display = \'none\';\n                    if (counter) { counter.classList.remove(\'hidden\'); if (qtyDisplay) qtyDisplay.textContent = getQty(); }\n                    updateCartCount(data);\n                });\n            });\n        }\n        if (buyBtn) {\n            buyBtn.addEventListener(\'click\', function (e) {\n                e.preventDefault();\n                const sku = buyBtn.dataset.sku, price = buyBtn.dataset.price;\n                postCart(sku, getQty(), price, getSize(container)).then(() => { window.location.href = \'/retail/checkout\'; });\n            });\n        }\n        if (minusBtn) {\n            minusBtn.addEventListener(\'click\', function () {\n                let val = parseInt(qtyDisplay.textContent);\n                const sku = addBtn.dataset.sku, price = addBtn.dataset.price;\n                if (val > 1) {\n                    val--;\n                    qtyDisplay.textContent = val;\n                    postCart(sku, val, price, getSize(container)).then(updateCartCount);\n                } else {\n                    postCart(sku, 0, price, getSize(container)).then(updateCartCount);\n                    counter.classList.add(\'hidden\');\n                    addBtn.style.display = \'\';\n                    if (qtyDisplay) qtyDisplay.textContent = 1;\n                }\n            });\n        }\n        if (plusBtn) {\n            plusBtn.addEventListener(\'click\', function () {\n                let val = parseInt(qtyDisplay.textContent);\n                if (val < 5) {\n                    val++;\n                    qtyDisplay.textContent = val;\n                    const sku = addBtn.dataset.sku, price = addBtn.dataset.price;\n                    postCart(sku, val, price, getSize(container)).then(updateCartCount);\n                }\n            });\n        }\n    });\n});\n</script>\n\n</main>\n\n\n<footer class="retail-footer">\n    <div class="footer-links">\n        <a href="/retail">Home</a>\n        <a href="/retail/categories">Categories</a>\n        <a href="/retail/checkout">Cart</a>\n        <a href="/retail/contact">Contact Us</a>\n    </div>\n    <div class="footer-copy">\n        <div>Nari Nakhre &copy; 2026. All Rights Reserved.</div>\n        <div>Handcrafted with <span style="color:#be185d">&#10084;</span> in India. &nbsp;|&nbsp;\n            <a href="mailto:info@narinakhre.com" style="color:#be185d;">info@narinakhre.com</a>\n        </div>\n    </div>\n</footer>\n\n\n<script src="/static/js/cart_global.js"></script>\n<script src="/static/js/retail_unit_counter.js"></script>\n<script src="/static/js/retail_cart_state.js"></script>\n<script>\nfunction syncCartCount(count) {\n    [\'cart-count\',\'cart-count-mobile\'].forEach(id => {\n        const el = document.getElementById(id);\n        if (el) el.innerText = count;\n    });\n}\nfunction retailAddToCart(btn) {\n    const c = btn.closest(\'.cart-container\');\n    const sku = btn.getAttribute(\'data-sku\'), price = btn.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = ss ? ss.value : \'Standard\';\n    fetch(\'/update-cart\', {method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body: JSON.stringify({product_id:sku,qty:1,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){\n            syncCartCount(d.new_total||d.cart_count||\'1\');\n            btn.classList.add(\'hidden\');\n            const uc = c.querySelector(\'.unit-counter\');\n            if(uc){uc.classList.remove(\'hidden\'); const qd=uc.querySelector(\'.qty-display\'); if(qd)qd.innerText=\'1\';}\n        }\n    });\n}\nfunction retailIncrement(btn) {\n    const c = btn.closest(\'.cart-container\'), uc = btn.closest(\'.unit-counter\');\n    const ab = c.querySelector(\'.add-to-cart-btn\');\n    const sku = ab.getAttribute(\'d