 setInterval(setHero, 5000);\n    }\n\n    /* ── Product image carousel ── */\n    document.querySelectorAll(\'img[id^="carousel-img-"]\').forEach(function (img) {\n        var imgs = [];\n        try { imgs = JSON.parse(img.getAttribute(\'data-images\') || \'[]\'); } catch(e) {}\n        if (imgs.length > 1) {\n            var idx = 0;\n            setInterval(function () {\n                idx = (idx + 1) % imgs.length;\n                img.src = imgs[idx];\n            }, 3000);\n        }\n    });\n});\n</script>\n\n</main>\n\n\n<footer class="w-full bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-rose-200 py-8 mt-16 border-t border-rose-900/20">\n    <div class="max-w-4xl mx-auto flex flex-col items-center gap-2 px-4 text-center">\n        <div class="mb-3">\n            <span class="font-semibold text-rose-300">Follow Us: </span>\n            <a href="https://fb.com/narinakhre" target="_blank"><img src="https://img.icons8.com/color/32/facebook-new.png" alt="Facebook" style="display:inline;height:26px;vertical-align:middle;margin:0 4px;"/></a>\n            <a href="https://instagram.com/narinakhre" target="_blank"><img src="https://img.icons8.com/color/32/instagram-new.png" alt="Instagram" style="display:inline;height:26px;vertical-align:middle;margin:0 4px;"/></a>\n        </div>\n        <div class="text-base font-bold rose-accent">Mohini Cosmetics</div>\n        <div class="text-sm">Shop No 136, Dharhai R Kotwali, Jabalpur, MP 482001</div>\n        <div class="text-sm">+91 99941 44994 &nbsp;|&nbsp; <a href="mailto:info@narinakhre.com" class="underline text-rose-300">info@narinakhre.com</a></div>\n        <div class="text-xs mt-3 opacity-70">&copy; 2026 Mohini Cosmetics. All rights reserved.</div>\n    </div>\n</footer>\n\n\n<script src="/static/js/cart_global.js"></script>\n<script src="/static/js/retail_unit_counter.js"></script>\n<script src="/static/js/retail_cart_state.js"></script>\n<script>\nfunction syncCartCount(count) {\n    [\'cart-count\',\'cart-count-mobile\'].forEach(id => {\n        const el = document.getElementById(id);\n        if (el) el.innerText = count;\n    });\n}\nfunction retailAddToCart(btn) {\n    const c = btn.closest(\'.cart-container\');\n    const sku = btn.getAttribute(\'data-sku\'), price = btn.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = ss ? ss.value : \'Standard\';\n    fetch(\'/update-cart\', {method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body: JSON.stringify({product_id:sku,qty:1,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){\n            syncCartCount(d.new_total||d.cart_count||\'1\');\n            btn.classList.add(\'hidden\');\n            const uc = c.querySelector(\'.unit-counter\');\n            if(uc){uc.classList.remove(\'hidden\'); const qd=uc.querySelector(\'.qty-display\'); if(qd)qd.innerText=\'1\';}\n        }\n    });\n}\nfunction retailIncrement(btn) {\n    const c = btn.closest(\'.cart-container\'), uc = btn.closest(\'.unit-counter\');\n    const ab = c.querySelector(\'.add-to-cart-btn\');\n    const sku = ab.getAttribute(\'data-sku\'), price = ab.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = ss ? ss.value : \'Standard\';\n    let qty = parseInt(uc.querySelector(\'.qty-display\').innerText)||1; qty++;\n    fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({product_id:sku,qty,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){uc.querySelector(\'.qty-display\').innerText=qty; syncCartCount(d.new_total||d.cart_count||\'1\');}\n    });\n}\nfunction retailDecrement(btn) {\n    const c = btn.closest(\'.cart-container\'), uc = btn.closest(\'.unit-counter\');\n    const ab = c.querySelector(\'.add-to-cart-btn\');\n    const sku = ab.getAttribute(\'data-sku\'), price = ab.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = ss ? ss.value : \'Standard\';\n    let qty = parseInt(uc.querySelector(\'.qty-display\').innerText)||1;\n    if(qty<=1){\n        fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n            body:JSON.stringify({product_id:sku,qty:0,price,size})})\n        .then(r=>r.json()).then(d=>{\n            if(d.status===\'success\'){uc.classList.add(\'hidden\'); ab.classList.remove(\'hidden\'); syncCartCount(d.new_total||d.cart_count||\'0\');}\n        }); return;\n    }\n    qty--;\n    fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({product_id:sku,qty,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){uc.querySelector(\'.qty-display\').innerText=qty; syncCartCount(d.new_total||d.cart_count||\'1\');}\n    });\n}\nfunction retailBuyNow(btn) {\n    const c = btn.closest(\'.cart-container\');\n    const sku = btn.getAttribute(\'data-sku\'), price = btn.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = ss ? ss.value : \'Standard\';\n    const uc = c.querySelector(\'.unit-counter\');\n    const qty = (uc && !uc.classList.contains(\'hidden\')) ? (parseInt(uc.querySelector(\'.qty-display\').innerText)||1) : 1;\n    fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({product_id:sku,qty,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){syncCartCount(d.new_total||d.cart_count||\'1\'); window.location.href=\'/retail/checkout\';}\n    });\n}\n</script>\n\n<script>\ndocument.addEventListener(\'DOMContentLoaded\', function() {\n    const btn = document.getElementById(\'categories-dropdown-btn\');\n    const menu = document.getElementById(\'categories-dropdown-menu\');\n    if (!btn || !menu) return;\n    btn.addEventListener(\'click\', function(e) {\n        e.stopPropagation();\n        const open = btn.getAttribute(\'aria-expanded\') === \'true\';\n        btn.setAttribute(\'aria-expanded\', !open);\n        menu.classList.toggle(\'hidden\');\n    });\n    document.addEventListener(\'click\', function() {\n        menu.classList.add(\'hidden\');\n        btn.setAttribute(\'aria-expanded\', \'false\');\n    });\n});\n</script>\n\n</body>\n</html>' : Retail checkout href found on wholesale home

