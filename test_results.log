lector(\'.ck-line-total\').textContent = \'₹\'+(qty*price).toFixed(0);\n        if(typeof syncCartCount===\'function\') syncCartCount(d.new_total||0);\n        ckRecalc();\n    });\n}\nfunction ckInc(btn) {\n    const row = btn.closest(\'.ck-item\');\n    const sku = row.dataset.sku, size = row.dataset.size, price = +row.dataset.price;\n    const qEl = row.querySelector(\'.ck-qty\');\n    const qty = +qEl.textContent + 1;\n    fetch(\'/update-cart\', {method:\'POST\', headers:{\'Content-Type\':\'application/json\'},\n        body: JSON.stringify({product_id:sku, qty, price, size})})\n    .then(r=>r.json()).then(d=>{\n        qEl.textContent = qty;\n        row.querySelector(\'.ck-line-total\').textContent = \'₹\'+(qty*price).toFixed(0);\n        if(typeof syncCartCount===\'function\') syncCartCount(d.new_total||0);\n        ckRecalc();\n    });\n}\nfunction ckRecalc() {\n    let sub = 0;\n    document.querySelectorAll(\'.ck-item\').forEach(r=>{\n        sub += +r.dataset.price * +r.querySelector(\'.ck-qty\').textContent;\n    });\n    document.getElementById(\'s-subtotal\').textContent = \'₹\'+sub.toFixed(0);\n    let disc = appliedCoupon ? Math.min(sub*(appliedCoupon.pct/100), appliedCoupon.max_discount>0?appliedCoupon.max_discount:Infinity) : discountBase;\n    if (appliedCoupon && sub < appliedCoupon.min_order) { disc = 0; }\n    currentDiscount = disc;\n    document.getElementById(\'s-total\').textContent = \'₹\'+Math.max(sub-disc,0).toFixed(0);\n}\n\n/* ── Coupon ── */\nfunction applyCoupon() {\n    const code = document.getElementById(\'ck-coupon\').value.trim().toUpperCase();\n    const msgEl = document.getElementById(\'ck-coupon-msg\');\n    if (!code) return;\n    fetch(\'/apply_coupon\', {method:\'POST\', headers:{\'Content-Type\':\'application/json\'},\n        body: JSON.stringify({coupon: code})})\n    .then(r=>r.json()).then(d=>{\n        msgEl.style.display = \'block\';\n        if (d.status === \'success\') {\n            msgEl.style.color = \'#15803d\';\n            msgEl.textContent = d.message;\n            setTimeout(()=>location.reload(), 600);\n        } else {\n            msgEl.style.color = \'#dc2626\';\n            msgEl.textContent = d.message || \'Invalid coupon code\';\n        }\n    }).catch(()=>{\n        msgEl.style.display=\'block\'; msgEl.style.color=\'#dc2626\';\n        msgEl.textContent=\'Could not apply coupon. Please try again.\';\n    });\n}\nfunction removeCoupon() {\n    fetch(\'/remove_coupon\', {method:\'POST\'}).then(()=>location.reload());\n}\n\n/* ── Clear cart ── */\ndocument.getElementById(\'ck-clear-btn\').addEventListener(\'click\', function(){\n    if(!confirm(\'Clear your entire bag?\')) return;\n    fetch(\'/clear_quote\',{method:\'POST\',headers:{\'X-Requested-With\':\'XMLHttpRequest\'}})\n    .then(r=>{ if(r.ok) location.reload(); });\n});\n\n/* ── Pincode check ── */\nlet ckPinTimer = null;\nfunction ckSetPinStatus(type, msg) {\n    const el = document.getElementById(\'ck-pin-status\');\n    el.className = \'ck-pin-status \' + (type||\'\');\n    el.textContent = msg || \'\';\n}\nfunction ckCheckPin() {\n    const pin = document.getElementById(\'ck-pin\').value.trim();\n    if (pin.length < 6) {\n        ckSetPinStatus(\'\', \'\');\n        // Don\'t reset ckServiceable while still typing\n        return;\n    }\n    clearTimeout(ckPinTimer);\n    ckPinTimer = setTimeout(()=>{\n        if (!/^\\d{6}$/.test(pin)) { ckSetPinStatus(\'err\',\'Invalid pincode\'); return; }\n        // Reset serviceability only right before we fire the API call\n        ckServiceable = false;\n        ckSetPinStatus(\'chk\',\'Checking availability…\');\n        document.getElementById(\'ck-city\').value = \'\';\n        document.getElementById(\'ck-state\').value = \'\';\n        fetch(\'/api/delhivery/check/\'+pin)\n        .then(r=>r.json())\n        .then(d=>{\n            if (d.serviceable || d.status) {\n                ckServiceable = true;\n                ckSetPinStatus(\'ok\', \'✓ Delivery available in \' + (d.city||pin));\n                document.getElementById(\'ck-city\').value = d.city || \'\';\n                document.getElementById(\'ck-state\').value = d.state || \'\';\n                ckFetchShipping(pin);\n            } else {\n                ckServiceable = false;\n                // Show a softer message — "not serviceable" could be an API hiccup\n                ckSetPinStatus(\'err\',\'Delivery not available at this pincode\');\n            }\n        })\n        .catch(()=>{\n            // API failed — don\'t show "not serviceable", show a neutral retry message\n            ckServiceable = false;\n            ckSetPinStatus(\'chk\',\'Could not verify — please check your pincode\');\n        });\n    }, 500);\n}\nfunction ckFetchShipping(pin) {\n    const mode = document.querySelector(\'input[name="payment_mode"]:checked\')?.value||\'Prepaid\';\n    fetch(\'/api/delhivery/shipping\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({pincode:pin,mode})})\n    .then(r=>r.json()).then(d=>{\n        ckShip=d.shipping_charge||0; ckCodFee=d.cod_fee||0;\n    }).catch(()=>{ ckShip=0; ckCodFee=0; });\n}\nfunction ckPayMode() {\n    const pin = document.getElementById(\'ck-pin\').value.trim();\n    if (ckServiceable && /^\\d{6}$/.test(pin)) ckFetchShipping(pin);\n}\n\n/* ── Form submit ── */\ndocument.getElementById(\'ck-form\').addEventListener(\'submit\', async function(e){\n    e.preventDefault();\n    const form = e.target;\n    const submitBtn = document.getElementById(\'ck-submit-btn\');\n    const name  = form.name.value.trim();\n    const phone = form.phone.value.trim();\n    const email = form.email.value.trim();\n    const addr  = form.address.value.trim();\n    const pin   = form.pincode.value.trim();\n    const mode  = form.payment_mode.value;\n    const city  = document.getElementById(\'ck-city\').value;\n\n    if (!/^\\d{6}$/.test(pin)) {\n        ckSetPinStatus(\'err\',\'Please enter a valid 6-digit pincode\');\n        document.getElementById(\'ck-pin\').focus();\n        return;\n    }\n    if (!ckServiceable) {\n        ckSetPinStatus(\'err\',\'Please wait — verifying delivery to this pincode…\');\n        document.getElementById(\'ck-pin\').focus();\n        return;\n    }\n\n    submitBtn.disabled = true;\n    submitBtn.textContent = \'Processing…\';\n\n    let sub = 0;\n    document.querySelectorAll(\'.ck-item\').forEach(r=>{\n        sub += +r.dataset.price * +r.querySelector(\'.ck-qty\').textContent;\n    });\n    const totalRupees = Math.max(sub - currentDiscount, 0);\n\n    const fd = new FormData();\n    fd.append(\'consignee_name\', name);\n    fd.append(\'consignee_phone\', phone);\n    fd.append(\'consignee_address\', addr);\n    fd.append(\'consignee_city\', city);\n    fd.append(\'consignee_state\', document.getElementById(\'ck-state\').value || \'\');\n    fd.append(\'consignee_pincode\', pin);\n    fd.append(\'payment_mode\', mode);\n    fd.append(\'email\', email);\n\n    try {\n        const r1 = await fetch(\'/retail/checkout/process\', {method:\'POST\', body:fd});\n        const d1 = await r1.json().catch(()=>({}));\n        if (!r1.ok || d1.status === \'error\') throw new Error(d1.message || \'Could not create order\');\n\n        if (mode === \'COD\') {\n            const r2 = await fetch(\'/api/confirm-cod\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({})});\n            const d2 = await r2.json();\n            if (d2.status === \'success\') { window.location.href = \'/thank_you\'; return; }\n            throw new Error(d2.message || \'Could not confirm COD order\');\n        }\n\n        const r3 = await fetch(\'/api/create-order\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({amount:totalRupees})});\n        const orderData = await r3.json();\n        if (orderData.status !== \'success\' || !orderData.order_id) throw new Error(orderData.message || \'Payment initiation failed\');\n\n        const rzp = new Razorpay({\n            key: orderData.key_id || RZP_KEY,\n            amount: orderData.amount,\n            currency: orderData.currency || \'INR\',\n            name: \'Nari Nakhre\',\n            description: \'Jewellery Order\',\n            image: \'/static/assets/logo.png\',\n            order_id: orderData.order_id,\n            prefill: {name, email, contact:phone},\n            theme: {color:\'#be185d\'},\n            handler: async function(resp){\n                const r4 = await fetch(\'/api/verify-payment\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n                    body:JSON.stringify({razorpay_order_id:resp.razorpay_order_id,razorpay_payment_id:resp.razorpay_payment_id,razorpay_signature:resp.razorpay_signature})});\n                const d4 = await r4.json();\n                if (d4.status===\'success\') window.location.href=\'/thank_you\';\n                else alert(d4.message||\'Payment verification failed\');\n            },\n            modal:{ondismiss:()=>{ submitBtn.disabled=false; submitBtn.textContent=\'Place Order\'; }}\n        });\n        rzp.open();\n    } catch(err) {\n        alert(err.message||\'Something went wrong. Please try again.\');\n        submitBtn.disabled=false; submitBtn.textContent=\'Place Order\';\n    }\n});\n</script>\n\n</main>\n\n\n<footer class="retail-footer">\n    <div class="footer-links">\n        <a href="/retail">Home</a>\n        <a href="/retail/categories">Categories</a>\n        <a href="/retail/checkout">Cart</a>\n        <a href="/retail/contact">Contact Us</a>\n    </div>\n    <div class="footer-copy">\n        <div>Nari Nakhre &copy; 2026. All Rights Reserved.</div>\n        <div>Handcrafted with <span style="color:#be185d">&#10084;</span> in India. &nbsp;|&nbsp;\n            <a href="mailto:info@narinakhre.com" style="color:#be185d;">info@narinakhre.com</a>\n        </div>\n    </div>\n</footer>\n\n\n<script src="/static/js/cart_global.js"></script>\n<script src="/static/js/retail_unit_counter.js"></script>\n<script src="/static/js/retail_cart_state.js"></script>\n<script>\nfunction syncCartCount(count) {\n    [\'cart-count\',\'cart-count-mobile\',\'cart-count-icon\'].forEach(id => {\n        const el = document.getElementById(id);\n        if (el) el.innerText = count;\n    });\n}\nfunction retailAddToCart(btn) {\n    const c = btn.closest(\'.cart-container\');\n    const sku = btn.getAttribute(\'data-sku\'), price = btn.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = (ss && ss.value && ss.value !== \'Standard\') ? ss.value : (ss ? ss.value : \'\');\n    fetch(\'/update-cart\', {method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body: JSON.stringify({product_id:sku,qty:1,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){\n            syncCartCount(d.new_total||d.cart_count||\'1\');\n            btn.classList.add(\'hidden\');\n            const uc = c.querySelector(\'.unit-counter\');\n            if(uc){uc.classList.remove(\'hidden\'); const qd=uc.querySelector(\'.qty-display\'); if(qd)qd.innerText=\'1\';}\n        }\n    });\n}\nfunction retailIncrement(btn) {\n    const c = btn.closest(\'.cart-container\'), uc = btn.closest(\'.unit-counter\');\n    const ab = c.querySelector(\'.add-to-cart-btn\');\n    const sku = ab.getAttribute(\'data-sku\'), price = ab.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = (ss && ss.value && ss.value !== \'Standard\') ? ss.value : (ss ? ss.value : \'\');\n    let qty = parseInt(uc.querySelector(\'.qty-display\').innerText)||1; qty++;\n    fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({product_id:sku,qty,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){uc.querySelector(\'.qty-display\').innerText=qty; syncCartCount(d.new_total||d.cart_count||\'1\');}\n    });\n}\nfunction retailDecrement(btn) {\n    const c = btn.closest(\'.cart-container\'), uc = btn.closest(\'.unit-counter\');\n    const ab = c.querySelector(\'.add-to-cart-btn\');\n    const sku = ab.getAttribute(\'data-sku\'), price = ab.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = (ss && ss.value && ss.value !== \'Standard\') ? ss.value : (ss ? ss.value : \'\');\n    let qty = parseInt(uc.querySelector(\'.qty-display\').innerText)||1;\n    if(qty<=1){\n        fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n            body:JSON.stringify({product_id:sku,qty:0,price,size})})\n        .then(r=>r.json()).then(d=>{\n            if(d.status===\'success\'){uc.classList.add(\'hidden\'); ab.classList.remove(\'hidden\'); syncCartCount(d.new_total||d.cart_count||\'0\');}\n        }); return;\n    }\n    qty--;\n    fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({product_id:sku,qty,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){uc.querySelector(\'.qty-display\').innerText=qty; syncCartCount(d.new_total||d.cart_count||\'1\');}\n    });\n}\nfunction retailBuyNow(btn) {\n    const c = btn.closest(\'.cart-container\');\n    const sku = btn.getAttribute(\'data-sku\'), price = btn.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = (ss && ss.value && ss.value !== \'Standard\') ? ss.value : (ss ? ss.value : \'\');\n    const uc = c.querySelector(\'.unit-counter\');\n    const qty = (uc && !uc.classList.contains(\'hidden\')) ? (parseInt(uc.querySelector(\'.qty-display\').innerText)||1) : 1;\n    fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({product_id:sku,qty,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){syncCartCount(d.new_total||d.cart_count||\'1\'); window.location.href=\'/retail/checkout\';}\n    });\n}\n</script>\n\n<script>\nfunction toggleMobileNav() {\n    document.getElementById(\'mobile-nav\').classList.toggle(\'open\');\n}\nfunction toggleMobileCats(btn) {\n    const list = document.getElementById(\'mobile-cat-list\');\n    list.classList.toggle(\'open\');\n    btn.querySelector(\'span\').textContent = list.classList.contains(\'open\') ? \'▴\' : \'▾\';\n}\nfunction verifyService() {\n    const pin = document.getElementById(\'pincode-input\').value;\n    const res = document.getElementById(\'pincode-result\');\n    if (!pin) { res.innerText = \'Enter a pincode\'; res.style.color = \'#6b7280\'; return; }\n    fetch(\'/api/delhivery/check/\' + pin).then(r=>r.json()).then(d=>{\n        res.innerText = d.status ? \'Deliverable ✓\' : \'Not Serviceable ✗\';\n        res.style.color = d.status ? \'#16a34a\' : \'#dc2626\';\n    }).catch(()=>{ res.innerText = \'Check failed\'; res.style.color = \'#dc2626\'; });\n}\n</script>\n\n</body>\n</html>' : Checkout missing inputmode — phone/pin keyboard UX will be poor on mobile

