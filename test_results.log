, price = ab.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = ss ? ss.value : \'Standard\';\n    let qty = parseInt(uc.querySelector(\'.qty-display\').innerText)||1; qty++;\n    fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({product_id:sku,qty,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){uc.querySelector(\'.qty-display\').innerText=qty; syncCartCount(d.new_total||d.cart_count||\'1\');}\n    });\n}\nfunction retailDecrement(btn) {\n    const c = btn.closest(\'.cart-container\'), uc = btn.closest(\'.unit-counter\');\n    const ab = c.querySelector(\'.add-to-cart-btn\');\n    const sku = ab.getAttribute(\'data-sku\'), price = ab.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = ss ? ss.value : \'Standard\';\n    let qty = parseInt(uc.querySelector(\'.qty-display\').innerText)||1;\n    if(qty<=1){\n        fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n            body:JSON.stringify({product_id:sku,qty:0,price,size})})\n        .then(r=>r.json()).then(d=>{\n            if(d.status===\'success\'){uc.classList.add(\'hidden\'); ab.classList.remove(\'hidden\'); syncCartCount(d.new_total||d.cart_count||\'0\');}\n        }); return;\n    }\n    qty--;\n    fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({product_id:sku,qty,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){uc.querySelector(\'.qty-display\').innerText=qty; syncCartCount(d.new_total||d.cart_count||\'1\');}\n    });\n}\nfunction retailBuyNow(btn) {\n    const c = btn.closest(\'.cart-container\');\n    const sku = btn.getAttribute(\'data-sku\'), price = btn.getAttribute(\'data-price\');\n    const ss = c.querySelector(\'.size-select\') || document.getElementById(\'size-main\');\n    const size = ss ? ss.value : \'Standard\';\n    const uc = c.querySelector(\'.unit-counter\');\n    const qty = (uc && !uc.classList.contains(\'hidden\')) ? (parseInt(uc.querySelector(\'.qty-display\').innerText)||1) : 1;\n    fetch(\'/update-cart\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},\n        body:JSON.stringify({product_id:sku,qty,price,size})})\n    .then(r=>r.json()).then(d=>{\n        if(d.status===\'success\'){syncCartCount(d.new_total||d.cart_count||\'1\'); window.location.href=\'/retail/checkout\';}\n    });\n}\n</script>\n\n<script>\nfunction toggleMobileNav() {\n    document.getElementById(\'mobile-nav\').classList.toggle(\'open\');\n}\nfunction toggleMobileCats(btn) {\n    const list = document.getElementById(\'mobile-cat-list\');\n    list.classList.toggle(\'open\');\n    btn.querySelector(\'span\').textContent = list.classList.contains(\'open\') ? \'▴\' : \'▾\';\n}\nfunction verifyService() {\n    const pin = document.getElementById(\'pincode-input\').value;\n    const res = document.getElementById(\'pincode-result\');\n    if (!pin) { res.innerText = \'Enter a pincode\'; res.style.color = \'#6b7280\'; return; }\n    fetch(\'/api/delhivery/check/\' + pin).then(r=>r.json()).then(d=>{\n        res.innerText = d.status ? \'Deliverable ✓\' : \'Not Serviceable ✗\';\n        res.style.color = d.status ? \'#16a34a\' : \'#dc2626\';\n    }).catch(()=>{ res.innerText = \'Check failed\'; res.style.color = \'#dc2626\'; });\n}\n</script>\n\n</body>\n</html>' : Wholesale mobile-stacking class missing from header — "ws-header-row" not found in response

